{
  "manifest_version": 3,
  "name": "253874 快速转发",
  "version": "0.1.0",
  "description": "一键将网页内容转发到里屋论坛（253874.net）",
  "permissions": ["contextMenus", "tabs", "scripting", "storage"],
  "host_permissions": ["https://www.253874.net/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["Readability.js","content.js"],
      "run_at": "document_idle"
    }
  ]
}